<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.NetflixPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/netflix_red</item>
        <item name="colorPrimaryVariant">@color/netflix_dark</item>
        <item name="colorOnPrimary">@color/netflix_white</item>
        <item name="colorSecondary">@color/netflix_red</item>
        <item name="colorSecondaryVariant">@color/netflix_dark</item>
        <item name="colorOnSecondary">@color/netflix_white</item>
        <item name="android:colorBackground">@color/netflix_dark</item>
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:navigationBarColor">@color/netflix_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.NetflixPlayer.Splash" parent="Theme.NetflixPlayer">
        <item name="android:windowBackground">@color/netflix_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.NetflixPlayer.Player" parent="Theme.NetflixPlayer">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
    </style>

    <style name="NetflixButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@color/netflix_red</item>
        <item name="android:textColor">@color/netflix_white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <style name="NetflixOutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/netflix_semi_white</item>
        <item name="android:textColor">@color/netflix_white</item>
        <item name="cornerRadius">4dp</item>
    </style>

</resources>
