<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/netflix_dark"
    android:keepScreenOn="true">

    <!-- ExoPlayer Video Surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:resize_mode="fit" />

    <!-- Brightness indicator (left swipe) -->
    <LinearLayout
        android:id="@+id/brightness_indicator"
        android:layout_width="56dp"
        android:layout_height="180dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="24dp"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#80000000"
        android:padding="10dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@color/netflix_white" />

        <ProgressBar
            android:id="@+id/pb_brightness"
            android:layout_width="8dp"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="50"
            android:rotation="180"
            android:indeterminate="false"
            android:progressDrawable="@drawable/seekbar_track" />

        <TextView
            android:id="@+id/tv_brightness_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="50%"
            android:textColor="@color/netflix_white"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Volume indicator (right swipe) -->
    <LinearLayout
        android:id="@+id/volume_indicator"
        android:layout_width="56dp"
        android:layout_height="180dp"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#80000000"
        android:padding="10dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_volume_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="@color/netflix_white" />

        <ProgressBar
            android:id="@+id/pb_volume"
            android:layout_width="8dp"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="50"
            android:rotation="180"
            android:indeterminate="false"
            android:progressDrawable="@drawable/seekbar_track" />

        <TextView
            android:id="@+id/tv_volume_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="50%"
            android:textColor="@color/netflix_white"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Seek feedback overlay (double tap) -->
    <LinearLayout
        android:id="@+id/seek_feedback_left"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="60dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏪"
            android:textSize="36sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 seconds"
            android:textColor="@color/netflix_white"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/seek_feedback_right"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="60dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏩"
            android:textSize="36sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 seconds"
            android:textColor="@color/netflix_white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Player Controls Overlay -->
    <RelativeLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60000000"
        android:visibility="gone">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/top_controls"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/netflix_white"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_circle" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_video_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video Title"
                    android:textColor="@color/netflix_white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tv_episode_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S1:E1 • Netflix Player"
                    android:textColor="@color/netflix_semi_white"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Cast -->
            <ImageView
                android:id="@+id/btn_cast"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_share"
                android:tint="@color/netflix_white"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_circle"
                android:layout_marginEnd="8dp" />

            <!-- Settings -->
            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:tint="@color/netflix_white"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_circle" />
        </LinearLayout>

        <!-- CENTER CONTROLS -->
        <LinearLayout
            android:id="@+id/center_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Skip Back 10s -->
            <LinearLayout
                android:id="@+id/btn_skip_back"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_circle">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_media_rew"
                    android:tint="@color/netflix_white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textColor="@color/netflix_white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Play/Pause -->
            <LinearLayout
                android:id="@+id/btn_play_pause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_circle">

                <ImageView
                    android:id="@+id/iv_play_pause"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_pause"
                    android:tint="@color/netflix_white" />
            </LinearLayout>

            <!-- Skip Forward 10s -->
            <LinearLayout
                android:id="@+id/btn_skip_forward"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ripple_circle">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:tint="@color/netflix_white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textColor="@color/netflix_white"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- BOTTOM CONTROLS -->
        <LinearLayout
            android:id="@+id/bottom_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/netflix_white"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_total_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/netflix_semi_white"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Seekbar -->
            <SeekBar
                android:id="@+id/seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:progressDrawable="@drawable/seekbar_track"
                android:thumb="@drawable/seekbar_thumb"
                android:thumbTint="@color/netflix_red"
                android:max="100" />

            <!-- Bottom actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Next Episode -->
                <ImageView
                    android:id="@+id/btn_next"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@color/netflix_white"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Volume -->
                <ImageView
                    android:id="@+id/btn_volume"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:layout_marginStart="12dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:tint="@color/netflix_white"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Lock screen -->
                <ImageView
                    android:id="@+id/btn_lock"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_lock_lock"
                    android:tint="@color/netflix_white"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="12dp" />

                <!-- Fullscreen -->
                <ImageView
                    android:id="@+id/btn_fullscreen"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_zoom"
                    android:tint="@color/netflix_white"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/netflix_red"
        android:visibility="gone" />

</RelativeLayout>
